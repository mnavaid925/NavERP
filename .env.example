# NavERP — environment template. Copy to .env and fill in.  (.env is gitignored.)

# --- Core Django ---
SECRET_KEY=change-me-to-a-50-char-random-string
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# --- Database (XAMPP MySQL/MariaDB) ---
DB_NAME=nav_erp
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# --- Email (dev uses the console backend; messages print to the runserver console) ---
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=NavERP <no-reply@naverp.local>

# --- Stripe (TEST MODE). Leave blank to run without online payments
#     (the app falls back to a manual "mark paid" flow). ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Test-mode recurring Price IDs (one per paid plan):
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
